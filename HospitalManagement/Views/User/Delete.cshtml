@model HospitalManagement.Models.AppUser
@{
    ViewData["Title"] = "Delete User";
}

<h1 class="mb-3 text-danger">Delete User</h1>

<div class="alert alert-warning">Are you sure you want to delete this user?</div>

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <p class="mb-1"><strong>Username:</strong> @Model.Username</p>
        <p class="mb-1"><strong>Email:</strong> @Model.Email</p>
        <p class="mb-0"><strong>Role:</strong> @Model.Role</p>
    </div>
</div>

<form asp-action="Delete" method="post" class="d-flex gap-2">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Confirm Delete</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
