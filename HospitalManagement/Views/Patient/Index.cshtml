@model IReadOnlyList<HospitalManagement.Models.Patient>
@{
    ViewData["Title"] = "Patients";
    var searchTerm = ViewData["SearchTerm"] as string;
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h1 class="mb-0">Patients</h1>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-person-plus"></i> Add New Patient</a>
</div>

<form method="get" asp-action="Index" class="row g-2 mb-3">
    <div class="col-md-9">
        <input type="text" name="searchTerm" value="@searchTerm" class="form-control" placeholder="Search patients..." />
    </div>
    <div class="col-md-3 d-grid d-md-flex gap-2">
        <button type="submit" class="btn btn-outline-primary">Search</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Age</th>
                    <th>Gender</th>
                    <th>Phone</th>
                    <th>Last Visit</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var patient in Model)
                    {
                        <tr>
                            <td>@patient.PatientCode</td>
                            <td>@patient.FirstName @patient.LastName</td>
                            <td>@patient.Age</td>
                            <td>@patient.Gender</td>
                            <td>@patient.PhoneNumber</td>
                            <td>@patient.LastVisitDate.ToLocalTime().ToString("yyyy-MM-dd")</td>
                            <td class="text-nowrap">
                                <a asp-action="Details" asp-route-id="@patient.Id" class="btn btn-sm btn-outline-info">Details</a>
                                <a asp-action="Edit" asp-route-id="@patient.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                <a asp-action="Delete" asp-route-id="@patient.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="7" class="text-center py-3">No patients found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
