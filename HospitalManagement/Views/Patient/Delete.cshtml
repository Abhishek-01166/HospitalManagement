@model HospitalManagement.Models.Patient
@{
    ViewData["Title"] = "Delete Patient";
}

<h1 class="mb-3 text-danger">Delete Patient</h1>

<div class="alert alert-warning">Are you sure you want to delete this patient record?</div>

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <p class="mb-1"><strong>Patient Code:</strong> @Model.PatientCode</p>
        <p class="mb-1"><strong>Name:</strong> @Model.FirstName @Model.LastName</p>
        <p class="mb-0"><strong>Phone:</strong> @Model.PhoneNumber</p>
    </div>
</div>

<form asp-action="Delete" method="post" class="d-flex gap-2">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Confirm Delete</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
