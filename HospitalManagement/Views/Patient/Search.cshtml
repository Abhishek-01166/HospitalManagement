@model HospitalManagement.ViewModels.PatientSearchViewModel
@{
    ViewData["Title"] = "Patient Search";
}

<h1 class="mb-4">Patient Search</h1>

<form method="get" asp-action="Search" class="row g-2 mb-4">
    <div class="col-md-8">
        <input type="text" name="searchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Search by code, name, phone, or email" />
    </div>
    <div class="col-md-4 d-grid d-md-flex gap-2">
        <button type="submit" class="btn btn-primary">Search</button>
        <a asp-action="Search" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

@if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
{
    <p class="text-muted">Search term: <strong>@Model.SearchTerm</strong></p>
}
else
{
    <p class="text-muted">Showing latest 10 patients by last visit date.</p>
}

<div class="table-responsive">
    <table class="table table-striped table-bordered">
        <thead class="table-light">
            <tr>
                <th>Patient Code</th>
                <th>Full Name</th>
                <th>Age</th>
                <th>Gender</th>
                <th>Phone Number</th>
                <th>Email</th>
                <th>Last Visit Date</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Results.Any())
        {
            @foreach (var patient in Model.Results)
            {
                <tr>
                    <td>@patient.PatientCode</td>
                    <td>@patient.FirstName @patient.LastName</td>
                    <td>@patient.Age</td>
                    <td>@patient.Gender</td>
                    <td>@patient.PhoneNumber</td>
                    <td>@patient.Email</td>
                    <td>@patient.LastVisitDate.ToLocalTime().ToString("yyyy-MM-dd")</td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7" class="text-center py-3">No patients found for this search.</td>
            </tr>
        }
        </tbody>
    </table>
</div>
