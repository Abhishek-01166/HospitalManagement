@model HospitalManagement.ViewModels.PatientSearchViewModel
@{
    ViewData["Title"] = "Patient Search";
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h1 class="mb-0">Patient Search</h1>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-person-plus"></i> Add New Patient</a>
</div>

<form method="get" asp-action="Search" class="card shadow-sm mb-4">
    <div class="card-body row g-2 align-items-end">
        <div class="col-md-9">
            <label class="form-label">Search</label>
            <input type="text" name="searchTerm" value="@Model.SearchTerm" class="form-control" placeholder="PatientCode, FirstName, LastName, Full Name, Phone, Email" />
        </div>
        <div class="col-md-3 d-grid d-md-flex gap-2">
            <button type="submit" class="btn btn-primary">Search</button>
            <a asp-action="Search" class="btn btn-outline-secondary">Clear</a>
        </div>
    </div>
</form>

<div class="card shadow-sm">
    <div class="card-header bg-white">
        @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
        {
            <span>Search term: <strong>@Model.SearchTerm</strong></span>
        }
        else
        {
            <span>Showing latest 10 patients by last visit date.</span>
        }
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Patient Code</th>
                    <th>Full Name</th>
                    <th>Phone</th>
                    <th>Email</th>
                    <th>Last Visit</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @if (Model.Results.Any())
            {
                @foreach (var patient in Model.Results)
                {
                    <tr>
                        <td>@patient.PatientCode</td>
                        <td>@patient.FirstName @patient.LastName</td>
                        <td>@patient.PhoneNumber</td>
                        <td>@patient.Email</td>
                        <td>@patient.LastVisitDate.ToLocalTime().ToString("yyyy-MM-dd")</td>
                        <td class="text-nowrap">
                            <a asp-action="Details" asp-route-id="@patient.Id" class="btn btn-sm btn-outline-info">Details</a>
                            <a asp-action="Edit" asp-route-id="@patient.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center py-3">No patients found for this search.</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
