@{
    ViewData["Title"] = "Main Menu";
}

<h1 class="mb-4">Main Menu</h1>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body d-flex flex-column">
                <h2 class="h5">Dashboard</h2>
                <p class="text-muted">View high-level patient statistics and recent visits.</p>
                <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary mt-auto">Go to Dashboard</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm h-100">
            <div class="card-body d-flex flex-column">
                <h2 class="h5">Patient Search</h2>
                <p class="text-muted">Search patients by code, name, phone number, or email.</p>
                <a asp-controller="Patient" asp-action="Search" class="btn btn-primary mt-auto">Search Patients</a>
            </div>
        </div>
    </div>
</div>
